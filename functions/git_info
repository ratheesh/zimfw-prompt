# Gets the Git special action (am, bisect, cherry, merge, rebase).
# Borrowed from vcs_info and edited.
function _git-action {
    local git_dir=$(git-dir 2>/dev/null)
    local action_dir
    for action_dir in \
        "${git_dir}/rebase-apply" \
            "${git_dir}/rebase" \
            "${git_dir}/../.dotest"
    do
        if [[ -d ${action_dir} ]]; then
            local apply_formatted
            local rebase_formatted
            apply_formatted="%F{8}Ώθβν %F{172}Όβζ %F{1}%{$italic%}%F{1}apply%{$reset%}%F{8}Ώθβο "
            rebase_formatted="%F{8}Ώθβν %F{172}Όβζ %F{1}%{$italic%}%F{1}>R>rebase%{$reset%}%F{8}Ώθβο "

            if [[ -f "${action_dir}/rebasing" ]]; then
                print ${rebase_formatted}
            elif [[ -f "${action_dir}/applying" ]]; then
                print ${apply_formatted}
            else
                print "${rebase_formatted}/${apply_formatted}"
            fi

            return 0
        fi
    done

    for action_dir in \
        "${git_dir}/rebase-merge/interactive" \
            "${git_dir}/.dotest-merge/interactive"
    do
        if [[ -f ${action_dir} ]]; then
            local rebase_interactive_formatted
            rebase_interactive_formatted="%F{8}Ώθβν %F{172}Όβζ %F{27}>%F{162}%BR%b%F{27}>%{$italic%}%F{1}rebase-i%{$reset%}%F{8}Ώθβο "
            print "${rebase_interactive_formatted}"
            return 0
        fi
    done

    for action_dir in \
        "${git_dir}/rebase-merge" \
            "${git_dir}/.dotest-merge"
    do
        if [[ -d ${action_dir} ]]; then
            local rebase_merge_formatted
            rebase_merge_formatted="%F{8}Ώθβν %F{172}Όβζ %F{1}Όχτ%{$italic%}rebase-merge%{$reset%}%F{8}Ώθβο "
            print ${rebase_merge_formatted}
            return 0
        fi
    done

    if [[ -f "${git_dir}/MERGE_HEAD" ]]; then
        local merge_formatted
        merge_formatted="%F{8}Ώθβν %F{172}Όβζ %F{1}Όχτ%{$italic%}merge%{$reset%}%F{8}Ώθβο "
        print ${merge_formatted}
        return 0
    fi

    if [[ -f "${git_dir}/CHERRY_PICK_HEAD" ]]; then
        if [[ -d "${git_dir}/sequencer" ]]; then
            local cherry_pick_sequence_formatted
            cherry_pick_sequence_formatted="%F{8}Ώθβν %F{172}Όβζ %F{1}ΌΛδ %{$italic%}cherry-pick-sequence%{$reset%}%F{8}Ώθβο "
            print ${cherry_pick_sequence_formatted}
        else
            local cherry_pick_formatted
            cherry_pick_formatted="%F{8}Ώθβν %F{172}Όβζ %F{1}ΌΛδ %{$italic%}cherry-pick%{$reset%}%F{8}Ώθβο "
            print ${cherry_pick_formatted}
        fi

        return 0
    fi

    if [[ -f "${git_dir}/BISECT_LOG" ]]; then
        local bisect_formatted
        bisect_formatted="%F{8}Ώθβν %F{172}Όβζ %F{1}<B>bisect%F{8}Ώθβο "
        print ${bisect_formatted}
        return 0
    fi

    return 1
}

# Prints the first non-empty string in the arguments array.
function coalesce {
    for arg in $argv; do
        print "$arg"
        return 0
    done
    return 1
}

function get_left_gitprompt_info() {
    local branch_name is_worktree branch
    branch_name="$(command git symbolic-ref -q --short HEAD 2> /dev/null)"
    local current_commit_hash tag_at_current_commit
    current_commit_hash="$(git rev-parse HEAD 2>/dev/null)"
    tag_at_current_commit=$(git describe --exact-match --tags $current_commit_hash 2> /dev/null)
    if [[ -n $tag_at_current_commit ]]; then
        tag_at_current_commit="%{$reset%}%F{97}έ╕ρ%b%{$italic%}%F{178}Όσο%{$reset%}%B%F{198}:%f%b%F{66}${tag_at_current_commit}%F{97}έ╕σ%f%b"
    fi
    [[ -n $branch_name ]] && [[ -f "$PWD/$(git rev-parse --show-cdup)/.git" ]] && is_worktree="%F{198}ΎΒΧ %f"
    if [[ -n $branch_name ]]; then
        branch=("%F{8}Ώθβπ %F{172}Όβζ %f${is_worktree:-""}%{$italic%}%F{37}%25>έΑο>${branch_name}%>>%F{142}${tag_at_current_commit:-""}%{$reset%}%F{8}Ώθβξ %f")
        [[ -n $is_worktree ]] && print -n "${branch:-""} $(_git-action)" || print -n "${branch:+""} $(_git-action)"
    fi
    unset is_worktree
}

function git_info() {
    local ahead=0 behind=0 untracked=0 modified=0 deleted=0 added=0 dirty=0 renamed=0 unmerged=0
    local branch position commit is_worktree
    local git_dir current_commit_hash branch_name tag_at_current_commit
    git_dir=$(git-dir 2>/dev/null)
    current_commit_hash="$(git rev-parse HEAD 2>/dev/null)"
    branch_name="${$(git symbolic-ref HEAD 2>/dev/null)#refs/heads/}"

    local tag_at_current_commit=$(git describe --exact-match --tags $current_commit_hash 2> /dev/null)
    if [[ -n $tag_at_current_commit ]]; then
        tag_at_current_commit="%{$reset%}%F{60}έ╕ρ%{$italic%}%F{178}Όσο%{$reset%}%F{198}:%f%F{66}${tag_at_current_commit}%F{60}έ╕σ%f"
    fi

    [[ -n $branch_name ]] && [[ -f "$PWD/$(git rev-parse --show-cdup)/.git" ]] && is_worktree="%F{198}ΎΒΧ %f"
    if [[ -n $branch_name ]]; then
        branch=("%F{8}Ώθβπ %F{172}Όβζ %F{9}%B${is_worktree:-""}%f%b%{$italic%}%F{37}%25>έΑο>${branch_name}%>>%F{142}${tag_at_current_commit:-""}%{$reset%}%F{8}Ώθβξ %f")
    else
        position="$(git describe --contains --all HEAD 2> /dev/null)"
        [[ -n $git_dir ]] && position="%F{8}╟Β%F{196}ΎΕπ %F{5}%{$italic%}${position}%{$reset%}%F{8}╟Β%f"
    fi

    [[ -n $git_dir ]] && [[ -z "$branch_name" && -z "$position" ]] && commit="ΎΕπ %F{8}╟Β%F{196}Ότ╝%F{7}${current_commit_hash}%F{8}╟Β%f"

    local ahead_and_behind_cmd='git rev-list --count --left-right HEAD...@{upstream}'
    local ahead_and_behind="$(${(z)ahead_and_behind_cmd} 2> /dev/null)"
    ahead="$ahead_and_behind[(w)1]"
    behind="$ahead_and_behind[(w)2]"

    local status_cmd="git status --porcelain --ignore-submodules=all"
    local -a git_status
    while IFS=$'\n' read line; do
        [[ "$line" == ([ACDMT][\ MT]|[ACMT]D)\ * ]] && (( added++ ))
        [[ "$line" == [\ ACMRT]D\ * ]] && (( deleted++ ))
        [[ "$line" == ?[MT]\ * ]] && (( modified++ ))
        [[ "$line" == R?\ * ]] && (( renamed++ ))
        [[ "$line" == (AA|DD|U?|?U)\ * ]] && (( unmerged++ ))
        [[ "$line" == \?\?\ * ]] && (( untracked++ ))
        (( dirty++ ))
    done < <(${(z)status_cmd} 2> /dev/null)

    if [[ -n $git_dir ]]; then
        (( dirty > 0 )) && git_status+=("%F{9}έεα%f") || git_status+=("%F{27}έεΦ%f")
        (( ahead > 0 && behind > 0 )) && git_status+=("%F{9}≤░Δ╗%f")
    fi

    git_status+=($(_git-action))
    git_status+=($(coalesce $branch $position $commit))

    local -i stashed=$(command git stash list 2>/dev/null | wc -l)
    (( stashed > 0 )) && git_status+=("%F{7}${stashed}%F{63}%BΎΣΦ%f%b")
    (( ahead > 0 )) && git_status+=("%F{7}${ahead}%F{34}≤░Βη%f")
    (( behind > 0 )) && git_status+=("%F{7}${behind}%F{198}≤░ΒΗ%f")
    (( added > 0 )) && git_status+=("%F{7}${added}%F{2}≤▒Θυ%f")
    (( deleted > 0 )) && git_status+=("%F{7}${deleted}%B%F{1}ΎΣπ %f%b")
    (( modified > 0 )) && git_status+=("%F{7}${modified}%F{202}έε▒%f")
    (( renamed > 0 )) && git_status+=("%F{7}${renamed}%F{54}ΎΖ╕ %f")
    (( unmerged > 0 )) && git_status+=("%F{7}${unmerged}%B%F{1}ΌΚ╣ %f%b")
    (( untracked > 0 )) && git_status+=("%F{7}${untracked}%F{8}??%f")

    unset is_worktree
    print -n "$git_status "
}

function transient_prompt_info() {
    local prompt_info
    local branch
    local git_dir=$(git-dir 2>/dev/null)
    local current_commit_hash="$(git rev-parse HEAD 2> /dev/null)"
    local branch_name="${$(git symbolic-ref HEAD 2> /dev/null)#refs/heads/}"

    # check if the current commit is at a tag point
    local tag_at_current_commit=$(git describe --exact-match --tags $current_commit_hash 2> /dev/null)
    if [[ -n $tag_at_current_commit ]]; then
        tag_at_current_commit="%{$reset%}%F{60}έ╕ρ%b%{$italic%}%F{178}Όσο%{$reset%}%B%F{198}:%f%b%F{66}${tag_at_current_commit}%F{60}έ╕σ%f%b"
    fi

    if [[ -n $branch_name ]];then
     branch=("%B%F{105}┬τ%B%F{172}Όβζ %f%b%{$italic%}%F{243}%25>έΑο>${$(git symbolic-ref HEAD 2> /dev/null)#refs/heads/}%>>%F{142}%b${tag_at_current_commit:-""}%{$reset%}%B%F{105}┬╗%f%b")
    fi

    if [[ -z "$branch_name" ]]; then
        pos="$(git describe --contains --all HEAD 2> /dev/null)"
        [[ -n $git_dir ]] && position="%B%F{8}╟Β%b%F{196}ΎΕπ %F{5}%{$italic%}${pos}%{$reset%}%B%F{8}╟Β%f%b"
        [[ -n $git_dir ]] && [[ -z "$branch_name" && -z "$pos" ]] && commit="ΎΕπ %B%F{8}╟Β%F{196}Ότ╝%F{7}${current_commit_hash}%B%F{8}╟Β%f%b"
    fi

    prompt_info="%B%F{129}≤░Υο%f%b%B%F{105}"
    prompt_info+=($(coalesce $branch $position $commit))

    print -n "$prompt_info"
}
